{
  "info": {
    "name": "Build Service",
    "description": "# Build Service\n\nBase URL: `http://localhost:8087`\n\nManages PC builds and their items. Supports full CRUD for both builds and build items, including error/edge-case scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Builds",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds",
        "description": "Retrieves all builds in the system. No filters or pagination applied."
      }
    },
    {
      "name": "Get Build By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds/1",
        "description": "Retrieves a single build by its ID. Returns 404 if not found."
      }
    },
    {
      "name": "Get Builds By User Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds/user/1",
        "description": "Retrieves all builds belonging to a specific user by user ID."
      }
    },
    {
      "name": "Get Build By Id And User Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds/user/1/1",
        "description": "Retrieves a specific build by both build ID and user ID."
      }
    },
    {
      "name": "Create Build",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{build_service}}/api/builds",
        "description": "Creates a new build for a user. Requires `userId` and `name`.\n\n**Expected:** 201 Created",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1,\n  \"name\": \"My New Build\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Create Build Invalid",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{build_service}}/api/builds",
        "description": "Negative test -- sends null `userId` and empty `name`.\n\n**Expected:** 400 Bad Request (validation error)",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": null,\n  \"name\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Update Build",
      "request": {
        "method": "PUT",
        "header": [],
        "url": "{{build_service}}/api/builds/1",
        "description": "Updates an existing build's name. Requires `userId` and `name`.\n\n**Expected:** 200 OK",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1,\n  \"name\": \"Updated Build Name\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Delete Build",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{build_service}}/api/builds/1",
        "description": "Deletes a build by ID.\n\n**Expected:** 204 No Content"
      }
    },
    {
      "name": "Delete Build Not Found",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{build_service}}/api/builds/9999",
        "description": "Negative test -- tries to delete a non-existent build.\n\n**Expected:** 404 Not Found"
      }
    },
    {
      "name": "Get Items By Build Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items",
        "description": "Retrieves all items associated with a specific build."
      }
    },
    {
      "name": "Get Item By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items/1",
        "description": "Retrieves a single item from a build by item ID. Returns 404 if not found."
      }
    },
    {
      "name": "Create Build Item",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items",
        "description": "Adds a product item to a build. Requires `productId` and `quantity` (> 0).\n\n**Expected:** 201 Created",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 101,\n  \"quantity\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Create Build Item Invalid Quantity",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items",
        "description": "Negative test -- sends quantity = 0 (must be > 0).\n\n**Expected:** 400 Bad Request (validation error)",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 101,\n  \"quantity\": 0\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Create Build Item Build Not Found",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{build_service}}/api/builds/9999/items",
        "description": "Negative test -- tries to add an item to a non-existent build.\n\n**Expected:** 404 Not Found",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": 101,\n  \"quantity\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Delete Build Item",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items/1",
        "description": "Deletes a specific item from a build.\n\n**Expected:** 204 No Content"
      }
    },
    {
      "name": "Delete Build Item Not Found",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{build_service}}/api/builds/1/items/9999",
        "description": "Negative test -- tries to delete a non-existent item.\n\n**Expected:** 404 Not Found"
      }
    }
  ]
}

{
  "info": {
    "name": "Category Service",
    "description": "# Category Service\n\nBase URL: `http://localhost:8084`\n\nManages product categories and their attribute definitions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{category_service}}/api/categories",
        "description": "Retrieves all categories in the system."
      }
    },
    {
      "name": "Get Category By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{category_service}}/api/categories/1",
        "description": "Retrieves a single category by ID. Returns 404 if not found."
      }
    },
    {
      "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{category_service}}/api/categories",
        "description": "Creates a new category. Required fields: `name`, `slug`.\n\n**Expected:** 201 Created",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"GPU\",\n  \"slug\": \"gpu\",\n  \"description\": \"Graphics cards\",\n  \"isActive\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Get Attributes By Category",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{category_service}}/api/categories/1/attributes",
        "description": "Retrieves attribute definitions for a category."
      }
    },
    {
      "name": "Create Attribute Definition",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{category_service}}/api/categories/1/attributes",
        "description": "Creates a new attribute definition for the category. Required fields: `attributeName`, `valueType`, `isRequired`.\n\n**Expected:** 201 Created",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"attributeName\": \"Chipset\",\n  \"valueType\": \"string\",\n  \"isRequired\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    }
  ]
}
